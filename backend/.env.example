# Copiez ce fichier en `.env` et renseignez vos propres valeurs.
# NE COMMITEZ JAMAIS le fichier `.env` (il est ignoré par Git).

# Base de données (SQLite par défaut, en local)
DATABASE_URL=sqlite+aiosqlite:///./dwwm_simulator.db

# Port du serveur backend
PORT=8000

# Clé API Google Gemini — à générer sur https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Modèle Gemini utilisé
GEMINI_MODEL=gemini-2.0-flash

# Secret JWT (authentification) — mettez une longue chaîne aléatoire en production
JWT_SECRET=dev-secret-change-me-in-production
